# Copy to .env and fill in for local development.

# PostgreSQL connection (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/marketmap?schema=public"

# Market data adapter (default: yahoo = public Yahoo chart + quote HTTP, no API key)
# MARKET_DATA_PROVIDER=yahoo

# Annual risk-free rate as a decimal, e.g. 4% => 0.04. Used in Sharpe ratio in domain services.
# RISK_FREE_ANNUAL=0.04
