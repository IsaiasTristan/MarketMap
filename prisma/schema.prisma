// MarketMap — PostgreSQL schema
// See docs/ARCHITECTURE.md for entity relationships and job flow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum RowLevel {
  SECTOR
  SUB_THEME
  COMPANY
}

enum MetricKind {
  RETURN
  EXCESS_RETURN
  VOLATILITY
  SHARPE
}

enum Horizon {
  D1
  D5
  M1
  M3
  M6
  Y1
}

enum BenchmarkCode {
  SP500
  NASDAQ
  DOW
}

enum RefreshJobType {
  MARKET_DATA
  BENCHMARK
  ANALYTICS
}

enum RefreshJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// --- Core reference ---

model Universe {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituents UniverseConstituent[]
  analyticsSnapshots AnalyticsSnapshot[]
}

/// One row per ticker in a universe; hierarchy fields drive map + rollups.
model UniverseConstituent {
  id          String   @id @default(cuid())
  universeId  String
  securityId  String
  sector      String
  subTheme    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  universe  Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)
  security  Security @relation(fields: [securityId], references: [id], onDelete: Restrict)

  @@unique([universeId, securityId])
  @@index([universeId, sector])
  @@index([universeId, subTheme])
}

/// Normalized tradable / listed instrument (equity or benchmark proxy).
model Security {
  id        String   @id @default(cuid())
  ticker    String   @unique // uppercase normalized in app layer
  name      String
  isActive  Boolean  @default(true)
  // Profile fields backfilled from Yahoo assetProfile
  sector    String?
  country   String?
  currency  String?
  assetClass String?
  // Delist tracking. Yahoo signals "delisted" via chart.error / 404 / 0-bar
  // pulls; we ratchet a counter here and only flag a candidate after a
  // sustained miss window so transient throttles don't poison the universe.
  firstMissedAt        DateTime?
  lastMissedAt         DateTime?
  consecutiveMisses    Int       @default(0)
  delistCandidate      Boolean   @default(false)
  delistedAt           DateTime?
  suggestedReplacement String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory       PriceHistory[]
  universeRows       UniverseConstituent[]
  portfolioPositions PortfolioPosition[]
  factorSnapshots    FactorExposureSnapshot[]
  fundamentals       SecurityFundamentals[]

  @@index([delistCandidate])
  @@index([isActive])
}

model PriceHistory {
  id          String   @id @default(cuid())
  securityId  String
  tradeDate   DateTime @db.Date
  adjClose    Decimal  @db.Decimal(20, 8)
  // optional raw fields for future use
  close       Decimal? @db.Decimal(20, 8)
  volume      BigInt?

  security Security @relation(fields: [securityId], references: [id], onDelete: Cascade)

  @@unique([securityId, tradeDate])
  @@index([tradeDate])
}

model Benchmark {
  id           String         @id @default(cuid())
  code         BenchmarkCode  @unique
  displayName  String
  proxyTicker  String // e.g. ^GSPC — also stored as Security if we ingest as series
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  priceHistory         BenchmarkPriceHistory[]
  analyticsMetricCells AnalyticsMetricCell[]
}

model BenchmarkPriceHistory {
  id           String   @id @default(cuid())
  benchmarkId  String
  tradeDate    DateTime @db.Date
  adjClose     Decimal  @db.Decimal(20, 8)

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, tradeDate])
  @@index([tradeDate])
}

// --- Users & roles (Cloudflare Access identity) ---

enum UserRole {
  ADMIN
  USER
}

/// One row per authenticated email seen via Cloudflare Access. Role is derived
/// from the ADMIN_EMAILS env allow-list at login and mirrored here. Normal
/// users are auto-provisioned on first visit; only the admin controls the
/// global universe / securities. `lastLoginAt` is throttled (<= 1 write/hour).
model User {
  id          String     @id @default(cuid())
  email       String     @unique
  role        UserRole   @default(USER)
  createdAt   DateTime   @default(now())
  lastLoginAt DateTime?

  portfolios  Portfolio[]
}

// --- Portfolio ---

model Portfolio {
  id        String   @id @default(cuid())
  name      String
  /// Owning user. Nullable so a safe `db push` + backfill is possible; the
  /// app always sets it on create and scopes reads/writes by the current user.
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions          PortfolioPosition[]
  factorSnapshots    FactorExposureSnapshot[]
  stressRuns         StressScenarioRun[]

  @@index([userId])
}

/// Single source of truth for a portfolio's holdings.
/// User supplies ticker + shares + L/S direction; weights are derived at
/// read time from shares × current price (gross + signed) so they reflect
/// today's allocation rather than a frozen snapshot.
/// Cash rows use isCash=true, cashAmount (dollars), shares=0, securityId=null.
model PortfolioPosition {
  id          String   @id @default(cuid())
  portfolioId String
  securityId  String?
  shares      Decimal  @db.Decimal(20, 8)
  isShort     Boolean  @default(false)
  isCash      Boolean  @default(false)
  cashAmount  Decimal? @db.Decimal(20, 8)
  sector      String?  // optional override; falls back to Security.sector
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  security  Security? @relation(fields: [securityId], references: [id], onDelete: Restrict)

  @@unique([portfolioId, securityId])
  @@index([securityId])
}

/// Fundamental data per security per date (for factor scoring).
model SecurityFundamentals {
  id               String   @id @default(cuid())
  securityId       String
  asOfDate         DateTime @db.Date
  marketCap        Decimal? @db.Decimal(30, 2)
  bookToPrice      Decimal? @db.Decimal(20, 8)
  earningsToPrice  Decimal? @db.Decimal(20, 8)
  fcfYield         Decimal? @db.Decimal(20, 8)
  roe              Decimal? @db.Decimal(20, 8)
  grossMargin      Decimal? @db.Decimal(20, 8)
  debtToEquity     Decimal? @db.Decimal(20, 8)
  earningsStability Decimal? @db.Decimal(20, 8)
  shortRatio       Decimal? @db.Decimal(20, 8)
  createdAt        DateTime @default(now())

  security Security @relation(fields: [securityId], references: [id], onDelete: Cascade)

  @@unique([securityId, asOfDate])
  @@index([asOfDate])
}

enum FactorCode {
  MKT_RF
  SMB
  HML
  RMW
  CMA
  MOM
  RF
  // Macro factors (asset-class beta) — added for MACRO14 model
  EQ
  LOCAL_EQ
  RATES
  COMM
  EM
  FX
  INFL
  // Style factors (cross-sectional risk premia) — added for MACRO14 model
  SHORT_VOL
  TREND
  BAB
  QMJ
  CROWD
}

enum FactorSource {
  FF     // official Fama-French published
  PROXY  // ETF-based proxy (gap period)
}

/// Daily factor returns from the unified factor pipeline.
model FactorReturnDaily {
  id         String       @id @default(cuid())
  tradeDate  DateTime     @db.Date
  factorCode FactorCode
  value      Decimal      @db.Decimal(20, 10) // already decimal (not pct)
  source     FactorSource

  @@unique([tradeDate, factorCode])
  @@index([tradeDate])
}

/// Singleton status record for the factor data pipeline.
model FactorPipelineStatus {
  id               String   @id @default(cuid())
  lastFrenchDate   DateTime? @db.Date
  gapTradingDays   Int      @default(0)
  activeProxiesJson Json    @default("{}")
  lastRefreshAt    DateTime?
  updatedAt        DateTime @updatedAt
}

/// Daily risk-free rate from FRED TB3MS (annualized).
model RiskFreeRate {
  id         String   @id @default(cuid())
  tradeDate  DateTime @db.Date @unique
  annualRate Decimal  @db.Decimal(10, 6) // e.g. 0.0525 = 5.25%

  @@index([tradeDate])
}

/// Key-value application settings (singleton per key).
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/// Append-only audit log for data changes.
model AuditLog {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  actor       String   @default("system")
  action      String
  payloadJson Json?

  @@index([at])
  @@index([action])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

/// Generated alerts surfaced in Module 9.
model Alert {
  id          String        @id @default(cuid())
  at          DateTime      @default(now())
  severity    AlertSeverity
  type        String        // "drawdown" | "stop_loss" | "factor_breach" | "crowding"
  message     String
  contextJson Json?
  dismissedAt DateTime?

  @@index([at, dismissedAt])
}

/// Cached historical scenario results per portfolio.
model StressScenarioRun {
  id           String   @id @default(cuid())
  portfolioId  String
  scenarioKey  String   // e.g. "2008_crisis" or "custom"
  asOfDate     DateTime @db.Date
  resultJson   Json
  createdAt    DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, scenarioKey, asOfDate])
  @@index([portfolioId])
}

// --- Analytics & factors ---

/// Roll-up of a market-map or similar analytics run for caching and audit.
model AnalyticsSnapshot {
  id               String    @id @default(cuid())
  universeId       String
  asOfTradeDate    DateTime? @db.Date // latest common date used in calcs
  methodologyLabel String    // e.g. version string for Sharpe/r_f
  createdAt        DateTime  @default(now())

  universe Universe           @relation(fields: [universeId], references: [id], onDelete: Cascade)
  cells    AnalyticsMetricCell[]
}

model AnalyticsMetricCell {
  id              String       @id @default(cuid())
  snapshotId      String
  rowLevel        RowLevel
  rowKey          String // sector name, sub-theme, or ticker
  metric          MetricKind
  horizon         Horizon
  benchmarkId     String?      // for excess return vs benchmark; null for others
  value           Decimal?     @db.Decimal(20, 10) // null if undefined (e.g. missing data)

  snapshot  AnalyticsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  benchmark Benchmark?        @relation(fields: [benchmarkId], references: [id], onDelete: SetNull)

  @@index([snapshotId, rowLevel, metric])
}

model FactorExposureSnapshot {
  id          String   @id @default(cuid())
  securityId  String?  // null if portfolio-level factor model later
  portfolioId String?
  asOfDate    DateTime @db.Date
  modelName   String
  factorsJson Json     // { "marketBeta": ..., "size": ..., ... }
  createdAt   DateTime @default(now())

  security Security? @relation(fields: [securityId], references: [id], onDelete: Cascade)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([asOfDate])
  @@index([securityId])
  @@index([portfolioId])
}

/// Precomputed per-stock factor regression grid, keyed by (model, window).
/// Lets the Factors tab load instantly: a daily pre-open job recomputes the
/// full-universe grid via runPerStockFactors and upserts the JSON blob here;
/// the API serves the cached row instead of recomputing ~300k regressions
/// per request. One row per (model, regressionWindow), overwritten each run.
model PerStockGridSnapshot {
  id               String   @id @default(cuid())
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  resultJson       Json
  computedAt       DateTime @default(now())

  @@unique([model, regressionWindow])
  @@index([model, regressionWindow])
}

/// Precomputed rolling factor-beta history for a portfolio, keyed by
/// (portfolioId, model, regressionWindow). Built by the daily job from the
/// engine's rolling OLS series (one beta vector per trading day over the
/// trailing window). Lets the Attribution tab's "Rolling Factor Betas" chart
/// load instantly from storage instead of recomputing per page view. One row
/// per (portfolioId, model, regressionWindow), overwritten each run.
model FactorRollingBetaSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  seriesJson       Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed market-map grid (rowLevel=COMPANY), keyed by
/// (universeId, metric, benchmark). The client fetches the COMPANY grid and
/// aggregates sector/sub-theme cells in-browser, so COMPANY is the only level
/// cached. The GET route reads this blob for non-overlay, unfiltered requests;
/// the extended-hours overlay and sector/sub-theme filters still compute live.
/// Built by the daily job + a market-hours background runner; cold misses
/// self-heal via live compute + write-through. One row per
/// (universeId, metric, benchmark), overwritten each refresh.
model MarketMapSnapshot {
  id          String   @id @default(cuid())
  universeId  String
  metric      String
  benchmark   String
  asOfDate    DateTime @db.Date
  payloadJson Json
  computedAt  DateTime @default(now())

  @@unique([universeId, metric, benchmark])
  @@index([universeId, metric, benchmark])
}

/// Precomputed Factors-tab exposure response (end-of-period betas, risk
/// decomposition, diagnostics), keyed by (portfolioId, model, regressionWindow).
/// Built from the same runFactorEngine pass as the rolling-beta snapshot. The
/// GET route reads this blob; cold misses self-heal via live compute +
/// write-through. One row per combo, overwritten each refresh.
model FactorExposureGridSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  payloadJson      Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed Factors-tab attribution response (daily/cumulative/period
/// summaries), keyed by (portfolioId, model, regressionWindow). Built by the
/// daily job + market-hours runner; cold misses self-heal via write-through.
model FactorAttributionSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  payloadJson      Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed universe-level MACRO14 factor-performance grid, keyed by
/// (metric, benchmark). Mirrors the market-map response shape so the Market
/// Map tab can reuse the heatmap renderer. Built by the daily job +
/// market-hours runner; cold misses self-heal via write-through.
model FactorPerformanceSnapshot {
  id          String   @id @default(cuid())
  metric      String
  benchmark   String
  asOfDate    DateTime @db.Date
  payloadJson Json
  computedAt  DateTime @default(now())

  @@unique([metric, benchmark])
  @@index([metric, benchmark])
}

// --- Operations ---

model RefreshJob {
  id          String             @id @default(cuid())
  type        RefreshJobType
  status      RefreshJobStatus   @default(PENDING)
  startedAt   DateTime?
  finishedAt  DateTime?
  errorMessage String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([status, createdAt])
}
