// MarketMap — PostgreSQL schema
// See docs/ARCHITECTURE.md for entity relationships and job flow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum RowLevel {
  SECTOR
  SUB_THEME
  COMPANY
}

enum MetricKind {
  RETURN
  EXCESS_RETURN
  VOLATILITY
  SHARPE
}

enum Horizon {
  D1
  D5
  M1
  M3
  M6
  Y1
}

enum BenchmarkCode {
  SP500
  NASDAQ
  DOW
}

enum RefreshJobType {
  MARKET_DATA
  BENCHMARK
  ANALYTICS
}

enum RefreshJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// Peer-group level for Engine 1 revision aggregates / z-scoring.
enum RevisionGroupType {
  SECTOR
  SUBSECTOR
}

// --- Core reference ---

model Universe {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  constituents UniverseConstituent[]
  analyticsSnapshots AnalyticsSnapshot[]
}

/// One row per ticker in a universe; hierarchy fields drive map + rollups.
model UniverseConstituent {
  id          String   @id @default(cuid())
  universeId  String
  securityId  String
  sector      String
  subTheme    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  universe  Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)
  security  Security @relation(fields: [securityId], references: [id], onDelete: Restrict)

  @@unique([universeId, securityId])
  @@index([universeId, sector])
  @@index([universeId, subTheme])
}

/// Normalized tradable / listed instrument (equity or benchmark proxy).
model Security {
  id        String   @id @default(cuid())
  ticker    String   @unique // uppercase normalized in app layer
  name      String
  isActive  Boolean  @default(true)
  // Profile fields backfilled from Yahoo assetProfile
  sector    String?
  country   String?
  currency  String?
  assetClass String?
  // Delist tracking. Yahoo signals "delisted" via chart.error / 404 / 0-bar
  // pulls; we ratchet a counter here and only flag a candidate after a
  // sustained miss window so transient throttles don't poison the universe.
  firstMissedAt        DateTime?
  lastMissedAt         DateTime?
  consecutiveMisses    Int       @default(0)
  delistCandidate      Boolean   @default(false)
  delistedAt           DateTime?
  suggestedReplacement String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory       PriceHistory[]
  universeRows       UniverseConstituent[]
  portfolioPositions PortfolioPosition[]
  factorSnapshots    FactorExposureSnapshot[]
  fundamentals       SecurityFundamentals[]

  @@index([delistCandidate])
  @@index([isActive])
}

model PriceHistory {
  id          String   @id @default(cuid())
  securityId  String
  tradeDate   DateTime @db.Date
  adjClose    Decimal  @db.Decimal(20, 8)
  // optional raw fields for future use
  close       Decimal? @db.Decimal(20, 8)
  volume      BigInt?

  security Security @relation(fields: [securityId], references: [id], onDelete: Cascade)

  @@unique([securityId, tradeDate])
  @@index([tradeDate])
}

model Benchmark {
  id           String         @id @default(cuid())
  code         BenchmarkCode  @unique
  displayName  String
  proxyTicker  String // e.g. ^GSPC — also stored as Security if we ingest as series
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  priceHistory         BenchmarkPriceHistory[]
  analyticsMetricCells AnalyticsMetricCell[]
}

model BenchmarkPriceHistory {
  id           String   @id @default(cuid())
  benchmarkId  String
  tradeDate    DateTime @db.Date
  adjClose     Decimal  @db.Decimal(20, 8)

  benchmark Benchmark @relation(fields: [benchmarkId], references: [id], onDelete: Cascade)

  @@unique([benchmarkId, tradeDate])
  @@index([tradeDate])
}

// --- Users & roles (Cloudflare Access identity) ---

enum UserRole {
  ADMIN
  USER
}

/// One row per authenticated email seen via Cloudflare Access. Role is derived
/// from the ADMIN_EMAILS env allow-list at login and mirrored here. Normal
/// users are auto-provisioned on first visit; only the admin controls the
/// global universe / securities. `lastLoginAt` is throttled (<= 1 write/hour).
model User {
  id          String     @id @default(cuid())
  email       String     @unique
  role        UserRole   @default(USER)
  createdAt   DateTime   @default(now())
  lastLoginAt DateTime?

  portfolios  Portfolio[]
}

// --- Portfolio ---

model Portfolio {
  id        String   @id @default(cuid())
  name      String
  /// Owning user. Nullable so a safe `db push` + backfill is possible; the
  /// app always sets it on create and scopes reads/writes by the current user.
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions          PortfolioPosition[]
  factorSnapshots    FactorExposureSnapshot[]
  stressRuns         StressScenarioRun[]

  @@index([userId])
}

/// Single source of truth for a portfolio's holdings.
/// User supplies ticker + shares + L/S direction; weights are derived at
/// read time from shares × current price (gross + signed) so they reflect
/// today's allocation rather than a frozen snapshot.
/// Cash rows use isCash=true, cashAmount (dollars), shares=0, securityId=null.
model PortfolioPosition {
  id          String   @id @default(cuid())
  portfolioId String
  securityId  String?
  shares      Decimal  @db.Decimal(20, 8)
  isShort     Boolean  @default(false)
  isCash      Boolean  @default(false)
  cashAmount  Decimal? @db.Decimal(20, 8)
  sector      String?  // optional override; falls back to Security.sector
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  security  Security? @relation(fields: [securityId], references: [id], onDelete: Restrict)

  @@unique([portfolioId, securityId])
  @@index([securityId])
}

/// Fundamental data per security per date (for factor scoring).
model SecurityFundamentals {
  id               String   @id @default(cuid())
  securityId       String
  asOfDate         DateTime @db.Date
  marketCap        Decimal? @db.Decimal(30, 2)
  bookToPrice      Decimal? @db.Decimal(20, 8)
  earningsToPrice  Decimal? @db.Decimal(20, 8)
  fcfYield         Decimal? @db.Decimal(20, 8)
  roe              Decimal? @db.Decimal(20, 8)
  grossMargin      Decimal? @db.Decimal(20, 8)
  debtToEquity     Decimal? @db.Decimal(20, 8)
  earningsStability Decimal? @db.Decimal(20, 8)
  shortRatio       Decimal? @db.Decimal(20, 8)
  createdAt        DateTime @default(now())

  security Security @relation(fields: [securityId], references: [id], onDelete: Cascade)

  @@unique([securityId, asOfDate])
  @@index([asOfDate])
}

enum FactorCode {
  MKT_RF
  SMB
  HML
  RMW
  CMA
  MOM
  RF
  // Macro factors (asset-class beta) — added for MACRO14 model
  EQ
  LOCAL_EQ
  RATES
  COMM
  EM
  FX
  INFL
  // Style factors (cross-sectional risk premia) — added for MACRO14 model
  SHORT_VOL
  TREND
  BAB
  QMJ
  CROWD
}

enum FactorSource {
  FF     // official Fama-French published
  PROXY  // ETF-based proxy (gap period)
}

/// Daily factor returns from the unified factor pipeline.
model FactorReturnDaily {
  id         String       @id @default(cuid())
  tradeDate  DateTime     @db.Date
  factorCode FactorCode
  value      Decimal      @db.Decimal(20, 10) // already decimal (not pct)
  source     FactorSource

  @@unique([tradeDate, factorCode])
  @@index([tradeDate])
}

/// Singleton status record for the factor data pipeline.
model FactorPipelineStatus {
  id               String   @id @default(cuid())
  lastFrenchDate   DateTime? @db.Date
  gapTradingDays   Int      @default(0)
  activeProxiesJson Json    @default("{}")
  lastRefreshAt    DateTime?
  updatedAt        DateTime @updatedAt
}

/// Daily risk-free rate from FRED TB3MS (annualized).
model RiskFreeRate {
  id         String   @id @default(cuid())
  tradeDate  DateTime @db.Date @unique
  annualRate Decimal  @db.Decimal(10, 6) // e.g. 0.0525 = 5.25%

  @@index([tradeDate])
}

/// Key-value application settings (singleton per key).
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/// Append-only audit log for data changes.
model AuditLog {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  actor       String   @default("system")
  action      String
  payloadJson Json?

  @@index([at])
  @@index([action])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

/// Generated alerts surfaced in Module 9.
model Alert {
  id          String        @id @default(cuid())
  at          DateTime      @default(now())
  severity    AlertSeverity
  type        String        // "drawdown" | "stop_loss" | "factor_breach" | "crowding"
  message     String
  contextJson Json?
  dismissedAt DateTime?

  @@index([at, dismissedAt])
}

/// Cached historical scenario results per portfolio.
model StressScenarioRun {
  id           String   @id @default(cuid())
  portfolioId  String
  scenarioKey  String   // e.g. "2008_crisis" or "custom"
  asOfDate     DateTime @db.Date
  resultJson   Json
  createdAt    DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, scenarioKey, asOfDate])
  @@index([portfolioId])
}

// --- Analytics & factors ---

/// Roll-up of a market-map or similar analytics run for caching and audit.
model AnalyticsSnapshot {
  id               String    @id @default(cuid())
  universeId       String
  asOfTradeDate    DateTime? @db.Date // latest common date used in calcs
  methodologyLabel String    // e.g. version string for Sharpe/r_f
  createdAt        DateTime  @default(now())

  universe Universe           @relation(fields: [universeId], references: [id], onDelete: Cascade)
  cells    AnalyticsMetricCell[]
}

model AnalyticsMetricCell {
  id              String       @id @default(cuid())
  snapshotId      String
  rowLevel        RowLevel
  rowKey          String // sector name, sub-theme, or ticker
  metric          MetricKind
  horizon         Horizon
  benchmarkId     String?      // for excess return vs benchmark; null for others
  value           Decimal?     @db.Decimal(20, 10) // null if undefined (e.g. missing data)

  snapshot  AnalyticsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  benchmark Benchmark?        @relation(fields: [benchmarkId], references: [id], onDelete: SetNull)

  @@index([snapshotId, rowLevel, metric])
}

model FactorExposureSnapshot {
  id          String   @id @default(cuid())
  securityId  String?  // null if portfolio-level factor model later
  portfolioId String?
  asOfDate    DateTime @db.Date
  modelName   String
  factorsJson Json     // { "marketBeta": ..., "size": ..., ... }
  createdAt   DateTime @default(now())

  security Security? @relation(fields: [securityId], references: [id], onDelete: Cascade)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([asOfDate])
  @@index([securityId])
  @@index([portfolioId])
}

/// Precomputed per-stock factor regression grid, keyed by (model, window).
/// Lets the Factors tab load instantly: a daily pre-open job recomputes the
/// full-universe grid via runPerStockFactors and upserts the JSON blob here;
/// the API serves the cached row instead of recomputing ~300k regressions
/// per request. One row per (model, regressionWindow), overwritten each run.
model PerStockGridSnapshot {
  id               String   @id @default(cuid())
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  resultJson       Json
  computedAt       DateTime @default(now())

  @@unique([model, regressionWindow])
  @@index([model, regressionWindow])
}

/// Precomputed rolling factor-beta history for a portfolio, keyed by
/// (portfolioId, model, regressionWindow). Built by the daily job from the
/// engine's rolling OLS series (one beta vector per trading day over the
/// trailing window). Lets the Attribution tab's "Rolling Factor Betas" chart
/// load instantly from storage instead of recomputing per page view. One row
/// per (portfolioId, model, regressionWindow), overwritten each run.
model FactorRollingBetaSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  seriesJson       Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed market-map grid (rowLevel=COMPANY), keyed by
/// (universeId, metric, benchmark). The client fetches the COMPANY grid and
/// aggregates sector/sub-theme cells in-browser, so COMPANY is the only level
/// cached. The GET route reads this blob for non-overlay, unfiltered requests;
/// the extended-hours overlay and sector/sub-theme filters still compute live.
/// Built by the daily job + a market-hours background runner; cold misses
/// self-heal via live compute + write-through. One row per
/// (universeId, metric, benchmark), overwritten each refresh.
model MarketMapSnapshot {
  id          String   @id @default(cuid())
  universeId  String
  metric      String
  benchmark   String
  asOfDate    DateTime @db.Date
  payloadJson Json
  computedAt  DateTime @default(now())

  @@unique([universeId, metric, benchmark])
  @@index([universeId, metric, benchmark])
}

/// Precomputed Factors-tab exposure response (end-of-period betas, risk
/// decomposition, diagnostics), keyed by (portfolioId, model, regressionWindow).
/// Built from the same runFactorEngine pass as the rolling-beta snapshot. The
/// GET route reads this blob; cold misses self-heal via live compute +
/// write-through. One row per combo, overwritten each refresh.
model FactorExposureGridSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  payloadJson      Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed Factors-tab attribution response (daily/cumulative/period
/// summaries), keyed by (portfolioId, model, regressionWindow). Built by the
/// daily job + market-hours runner; cold misses self-heal via write-through.
model FactorAttributionSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  model            String
  regressionWindow Int
  asOfDate         DateTime @db.Date
  payloadJson      Json
  computedAt       DateTime @default(now())

  @@unique([portfolioId, model, regressionWindow])
  @@index([portfolioId, model, regressionWindow])
}

/// Precomputed universe-level MACRO14 factor-performance grid, keyed by
/// (metric, benchmark). Mirrors the market-map response shape so the Market
/// Map tab can reuse the heatmap renderer. Built by the daily job +
/// market-hours runner; cold misses self-heal via write-through.
model FactorPerformanceSnapshot {
  id          String   @id @default(cuid())
  metric      String
  benchmark   String
  asOfDate    DateTime @db.Date
  payloadJson Json
  computedAt  DateTime @default(now())

  @@unique([metric, benchmark])
  @@index([metric, benchmark])
}

// --- Operations ---

model RefreshJob {
  id          String             @id @default(cuid())
  type        RefreshJobType
  status      RefreshJobStatus   @default(PENDING)
  startedAt   DateTime?
  finishedAt  DateTime?
  errorMessage String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([status, createdAt])
}

// ===========================================================================
// Engine 1 — Analyst Revision Detector (FMP-backed)
//
// A self-contained, append-only point-in-time store. The store is keyed by
// (ticker, snapshotDate) and is NEVER overwritten: each row reflects only what
// was knowable on its date, so trajectory is queryable and future backtests are
// look-ahead-free. Ingestion writes raw rows (RevisionSnapshot + the Leg-B
// event tables); signal computation writes RevisionScore on the SAME key, so
// signal logic can change without touching ingestion and a second engine can
// extend the same key / reuse RevisionReference.
// ===========================================================================

/// Reference / classification table for the Engine 1 universe (decoupled from
/// the market-map Universe/Security). Populated from FMP screener + profile.
/// Shared by a future Engine 2.
model RevisionReference {
  id              String   @id @default(cuid())
  ticker          String   @unique // uppercase normalized in app layer
  companyName     String
  cik             String?
  sector          String? // FMP sector
  subsector       String? // FMP industry — the default peer set for z-scoring
  exchange        String?
  country         String?
  currency        String?
  marketCap       Decimal? @db.Decimal(20, 2)
  identifiersJson Json? // { isin, cusip, ... } — extensible, often spotty
  isActive        Boolean  @default(true)
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime?

  @@index([sector])
  @@index([subsector])
  @@index([isActive])
}

/// Append-only weekly per-stock snapshot holding both legs' consensus as-of the
/// snapshot date. Leg A (estimates) has no source history — this store IS its
/// revision history. A few leading metrics are typed for fast querying; the
/// spotty multi-period estimate matrix lives in estimatesJson.
model RevisionSnapshot {
  id                 String   @id @default(cuid())
  ticker             String
  snapshotDate       DateTime @db.Date
  // Leg A — leading estimate consensus (forward fiscal period), absolute $.
  revenueAvg         Decimal? @db.Decimal(24, 4)
  epsAvg             Decimal? @db.Decimal(20, 6)
  numAnalystsRevenue Int?
  numAnalystsEps     Int?
  // Leg B — current consensus snapshot.
  ptConsensus        Decimal? @db.Decimal(20, 6)
  ptHigh             Decimal? @db.Decimal(20, 6)
  ptLow              Decimal? @db.Decimal(20, 6)
  ptMedian           Decimal? @db.Decimal(20, 6)
  numPriceTargets    Int?
  nextEarningsDate   DateTime? @db.Date
  // Spotty / multi-field detail.
  estimatesJson      Json? // per fiscal period: revenue/ebitda/ebit/netIncome/sga/eps {low,avg,high} + counts
  ratingsJson        Json? // grades-consensus distribution + price-target-summary periods
  source             String   @default("FMP")
  createdAt          DateTime @default(now())

  @@unique([ticker, snapshotDate])
  @@index([snapshotDate])
  @@index([ticker])
}

/// Leg B event-level analyst grade changes (FMP /grades). Backtestable on day
/// one: backfilled in full on first run, then tailed weekly. Append-only.
model RatingEvent {
  id             String   @id @default(cuid())
  ticker         String
  eventDate      DateTime @db.Date
  gradingCompany String?
  previousGrade  String?
  newGrade       String?
  action         String? // upgrade | downgrade | maintain | initiate | ...
  source         String   @default("FMP")
  createdAt      DateTime @default(now())

  @@unique([ticker, eventDate, gradingCompany, newGrade])
  @@index([ticker, eventDate])
  @@index([eventDate])
}

/// Leg B event-level price-target changes (FMP /price-target-news).
/// Backfilled on first run, tailed weekly. Append-only.
model PriceTargetEvent {
  id              String    @id @default(cuid())
  ticker          String
  publishedDate   DateTime
  analystCompany  String?
  analystName     String?
  priceTarget     Decimal?  @db.Decimal(20, 6)
  priceWhenPosted Decimal?  @db.Decimal(20, 6)
  newsPublisher   String?
  source          String    @default("FMP")
  createdAt       DateTime  @default(now())

  @@unique([ticker, publishedDate, analystCompany, priceTarget])
  @@index([ticker, publishedDate])
  @@index([publishedDate])
}

/// Sector / subsector aggregate weekly snapshot (rotation + breadth heatmap
/// inputs). Append-only, keyed by (groupType, groupKey, snapshotDate).
model RevisionSectorAggregate {
  id            String            @id @default(cuid())
  groupType     RevisionGroupType
  groupKey      String // sector name or subsector (industry) name
  snapshotDate  DateTime          @db.Date
  breadth       Float?
  compositeMean Float?
  nameCount     Int?
  aggregatesJson Json? // per-signal means / breadth detail
  createdAt     DateTime          @default(now())

  @@unique([groupType, groupKey, snapshotDate])
  @@index([groupType, snapshotDate])
}

/// Computed signal / score layer, keyed on the SAME (ticker, snapshotDate) as
/// RevisionSnapshot but written by the signal service, not ingestion. Holds
/// per-signal z-scores, the composite, deciles, and the week-over-week
/// new-arrival flag (change detector).
model RevisionScore {
  id              String            @id @default(cuid())
  ticker          String
  snapshotDate    DateTime          @db.Date
  peerGroupType   RevisionGroupType
  peerGroupKey    String
  composite       Float?
  subsectorDecile Int?
  sectorDecile    Int?
  rank            Int?
  newArrival      Boolean           @default(false)
  scoreJson       Json? // all raw signals + their z-scores
  createdAt       DateTime          @default(now())

  @@unique([ticker, snapshotDate])
  @@index([snapshotDate])
  @@index([snapshotDate, rank])
}

/// Weekly ranked research-queue output cache (master rank table payload).
/// One row per snapshotDate, overwritten on recompute.
model ResearchQueueSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @unique @db.Date
  payloadJson  Json
  computedAt   DateTime @default(now())
}

// ===========================================================================
// Engine 2 — Fundamental-Inflection Discovery (FMP-backed)
//
// Extends Engine 1's append-only point-in-time design — same (ticker,
// snapshotDate) weekly key, reuses RevisionReference (universe + sector
// taxonomy) and RevisionGroupType (peer level) — rather than forking a parallel
// store. Detects margin/growth/FCF/ROIC inflections + deleveraging, applies
// quality filters (accruals trap, compounder consistency) and an intra-ticker
// valuation-vs-own-history signal.
//
// Phase 0 (scripts/fundamental-fmp-validate.ts, live key): 32 quarters (~8yr)
// of income/balance/cash-flow/ratios/key-metrics on mega + small-caps; OCF +
// capex 32/32 covered on every small-cap (accruals inputs safe); FMP's gross
// margin / FCF / EV reconcile exactly to our line-item formulas, but FMP's
// `ebitda` field diverges structurally on small/loss-making names — so EBITDA
// (and EBITDA-margin / net-debt-to-EBITDA) are computed OUR way (= operating
// income + D&A) and stored; ROIC/ROE are trusted from FMP; FMP raw values are
// retained in JSON for reconciliation.
// ===========================================================================

/// Provenance of a stored fiscal-period row. Pre-launch BACKFILL rows are
/// restated-basis: their `firstSeenSnapshotDate` is the backfill date, NOT a
/// true filing date, so as-first-reported semantics are intentionally fictional
/// for them and must not be read as point-in-time truth. Only LIVE rows
/// (captured weekly after launch) carry genuine as-first-reported integrity,
/// and only LIVE-vs-LIVE differences are treated as restatements.
enum FundamentalProvenance {
  BACKFILL
  LIVE
}

/// As-first-reported (for LIVE rows) fiscal-period statement facts + derived
/// fields, keyed (ticker, fiscalDate, periodType). Written once — never
/// overwritten — so trajectory is queryable and backtests are look-ahead-free
/// for the LIVE span. Derived EBITDA/FCF/margins/accruals are stored (the value
/// as computed from data known that date) to preserve point-in-time integrity.
model FundamentalPeriod {
  id                       String                @id @default(cuid())
  ticker                   String
  fiscalDate               DateTime              @db.Date
  periodType               String // "annual" | "quarter"
  fiscalLabel              String? // FY | Q1..Q4
  // typed core line items (as-first-reported for LIVE rows)
  revenue                  Decimal?              @db.Decimal(24, 4)
  grossProfit              Decimal?              @db.Decimal(24, 4)
  operatingIncome          Decimal?              @db.Decimal(24, 4)
  netIncome                Decimal?              @db.Decimal(24, 4)
  depreciationAmortization Decimal?              @db.Decimal(24, 4)
  ebitda                   Decimal?              @db.Decimal(24, 4) // DERIVED = operatingIncome + D&A
  totalDebt                Decimal?              @db.Decimal(24, 4)
  cash                     Decimal?              @db.Decimal(24, 4)
  totalAssets              Decimal?              @db.Decimal(24, 4)
  totalEquity              Decimal?              @db.Decimal(24, 4)
  preferredEquity          Decimal?              @db.Decimal(24, 4)
  minorityInterest         Decimal?              @db.Decimal(24, 4)
  operatingCashFlow        Decimal?              @db.Decimal(24, 4)
  capex                    Decimal?              @db.Decimal(24, 4)
  freeCashFlow             Decimal?              @db.Decimal(24, 4) // DERIVED = OCF + capex
  sharesDiluted            Decimal?              @db.Decimal(24, 4)
  // additive line items for the multi-box discovery model (nullable, write-once)
  interestExpense          Decimal?              @db.Decimal(24, 4)
  stockBasedCompensation   Decimal?              @db.Decimal(24, 4)
  changeInWorkingCapital   Decimal?              @db.Decimal(24, 4) // FMP cash-flow effect (positive = cash source)
  commonStockIssued        Decimal?              @db.Decimal(24, 4) // FMP commonStockIssuance (>= 0)
  commonStockRepurchased   Decimal?              @db.Decimal(24, 4) // FMP commonStockRepurchased (<= 0, cash outflow)
  // derived ratios computed at the storage boundary
  grossMargin              Float?
  ebitdaMargin             Float?
  operatingMargin          Float?
  netMargin                Float?
  roic                     Float? // trusted from FMP
  roe                      Float?
  netDebtToEbitda          Float?
  // valuation multiples priced at the fiscal date (FMP key-metrics) — own-history series
  peRatio                  Float?
  evToEbitda               Float?
  priceToSales             Float?
  dividendYield            Float?
  fcfYield                 Float?
  interestCoverage         Float?
  // raw FMP (verify-before-trust) + extra line items
  statementJson            Json?
  ratiosJson               Json?
  provenance               FundamentalProvenance @default(LIVE)
  firstSeenSnapshotDate    DateTime              @db.Date
  source                   String                @default("FMP")
  createdAt                DateTime              @default(now())

  @@unique([ticker, fiscalDate, periodType])
  @@index([ticker, periodType, fiscalDate])
  @@index([fiscalDate])
}

/// Append-only weekly point-in-time snapshot: the latest filed figures known on
/// `snapshotDate` (TTM leading metrics + current valuation multiples priced at
/// the snapshot) plus a `metricsJson` carrying the trailing per-period series
/// the signals consume and the own-history valuation percentiles. Keyed
/// (ticker, snapshotDate), never overwritten.
model FundamentalSnapshot {
  id               String   @id @default(cuid())
  ticker           String
  snapshotDate     DateTime @db.Date
  latestFiscalDate DateTime? @db.Date
  // typed leading metrics known as-of (TTM / latest)
  revenueTtm       Decimal? @db.Decimal(24, 4)
  grossMargin      Float?
  ebitdaMargin     Float?
  operatingMargin  Float?
  netMargin        Float?
  roic             Float?
  roe              Float?
  fcfTtm           Decimal? @db.Decimal(24, 4)
  fcfMargin        Float?
  revenueGrowthYoy Float?
  netDebtToEbitda  Float?
  accrualsRatio    Float?
  // current valuation multiples (priced at snapshot via live quote)
  peRatio          Decimal? @db.Decimal(20, 6)
  evToEbitda       Decimal? @db.Decimal(20, 6)
  priceToSales     Decimal? @db.Decimal(20, 6)
  marketCap        Decimal? @db.Decimal(30, 2)
  enterpriseValue  Decimal? @db.Decimal(30, 2)
  metricsJson      Json?
  source           String   @default("FMP")
  createdAt        DateTime @default(now())

  @@unique([ticker, snapshotDate])
  @@index([snapshotDate])
  @@index([ticker])
}

/// Computed signal / score layer for Engine 2, keyed on the same (ticker,
/// snapshotDate) as FundamentalSnapshot but written by the scoring service.
/// Cross-sectional inflection signals are z-scored within subsector (sector
/// fallback); the valuation-vs-own-history signal is intra-ticker (percentile,
/// not z-scored). Quality filters set trapFlag / compounderScore.
model FundamentalScore {
  id              String            @id @default(cuid())
  ticker          String
  snapshotDate    DateTime          @db.Date
  peerGroupType   RevisionGroupType
  peerGroupKey    String
  composite       Float?
  subsectorDecile Int?
  sectorDecile    Int?
  rank            Int?
  newArrival      Boolean           @default(false)
  trapFlag        Boolean           @default(false)
  compounderScore Float?
  valuationPercentile Float?
  /// Calculation-version identifier (e.g. "discovery_9_box_v1.0") so methodology
  /// changes do not silently alter prior historical scores.
  scoreMethodologyVersion String?
  scoreJson       Json?
  createdAt       DateTime          @default(now())

  @@unique([ticker, snapshotDate])
  @@index([snapshotDate])
  @@index([snapshotDate, rank])
}

/// Sector / subsector aggregate weekly snapshot for Engine 2 (rotation /
/// breadth of the inflection composite). Append-only.
model FundamentalSectorAggregate {
  id                   String            @id @default(cuid())
  groupType            RevisionGroupType
  groupKey             String
  snapshotDate         DateTime          @db.Date
  marginInflectionMean Float?
  compositeMean        Float?
  nameCount            Int?
  aggregatesJson       Json?
  createdAt            DateTime          @default(now())

  @@unique([groupType, groupKey, snapshotDate])
  @@index([groupType, snapshotDate])
}

/// Weekly ranked discovery-queue output cache (master discovery payload).
/// One row per snapshotDate, overwritten on recompute.
model DiscoveryQueueSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @unique @db.Date
  payloadJson  Json
  computedAt   DateTime @default(now())
}

/// Per-report earnings actuals + the consensus immediately before the report,
/// sourced from FMP /stable/earnings (the consensus is FMP's estimate at the
/// announcement, never updated after the release). Keyed (ticker, reportDate);
/// write-once (existing figures never overwritten). Feeds the Earnings &
/// Revenue Surprise box and the residual-return-since-last-earnings momentum
/// component. `reportDate` is the announcement date; FMP does not currently
/// expose a BMO/AMC field on this endpoint (see AGENTS.md data risks).
model EarningsSurprise {
  id                    String   @id @default(cuid())
  ticker                String
  reportDate            DateTime @db.Date
  epsActual             Decimal? @db.Decimal(20, 6)
  epsEstimated          Decimal? @db.Decimal(20, 6)
  revenueActual         Decimal? @db.Decimal(24, 4)
  revenueEstimated      Decimal? @db.Decimal(24, 4)
  source                String   @default("FMP")
  firstSeenSnapshotDate DateTime @db.Date
  createdAt             DateTime @default(now())

  @@unique([ticker, reportDate])
  @@index([ticker, reportDate])
}

// ===========================================================================
// Engine 3 — Institutional Capital-Flow Discovery (13F, FMP-backed)
//
// The lagging confirmation layer. Quarterly, backfillable day-one. Mirrors the
// Engine 1/2 append-only, period-keyed design (here keyed by `filingPeriod` =
// 13F period-of-report / quarter-end) and reuses RevisionReference (sector /
// subsector / marketCap taxonomy) + RevisionGroupType (peer level). NO composite
// scores — raw counts + two visible axes (breadth, conviction) + categorical
// labels only, diffed vs the prior quarter (change detector).
//
// Phase 0 (scripts/institutional-fmp-validate.ts, live key): 68/68 watchlist
// CIKs resolve; per-fund holdings via /stable/institutional-ownership/extract
// (full, un-paginated; carries symbol + shares + value$); total book via
// holder-performance-summary; history backfillable to ~2013; small/mid-cap
// coverage strong (edge zone). A fund can report multiple rows per symbol
// (share classes + PUT/CALL) — ingestion aggregates to one long-equity position
// per (fund, ticker, period) and excludes put/call from the accumulation signal
// (raw rows retained in rawJson).
// ===========================================================================

/// Position lifecycle for a (fund, ticker) vs its prior filing period.
enum InstitutionalAction {
  NEW
  ADDED
  HELD
  TRIMMED
  EXITED
}

/// Editable watchlist (~68 curated funds, seeded from the CIK list, then
/// user-maintained via the admin UI). `cik` is the 10-digit zero-padded filer id.
model InstitutionalFund {
  id              String   @id @default(cuid())
  cik             String   @unique
  name            String // display name
  edgarName       String? // EDGAR 13F-HR filer name
  tier            Int      @default(1) // 1 growth/quality · 2 value · 3 activist
  isMostRespected Boolean  @default(false) // hand-weighted subset → first-mover view
  isActive        Boolean  @default(true) // include in aggregates
  notes           String?
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  holdings FundHoldingSnapshot[]
  books    FundBookSnapshot[]

  @@index([isActive])
  @@index([tier])
}

/// Fact table: one aggregated long-equity position per (fund, ticker, period).
/// Append-only / write-once per key. `action` is set by the diff layer.
model FundHoldingSnapshot {
  id           String              @id @default(cuid())
  fundId       String
  cik          String
  filingPeriod DateTime            @db.Date // quarter-end / period-of-report
  ticker       String
  cusip        String?
  nameOfIssuer String?
  shares       Decimal             @db.Decimal(24, 2) // common shares (puts/calls excluded)
  value        Decimal             @db.Decimal(24, 2) // reported $ value
  pctOfBook    Float? // value / fund total book — the conviction dimension
  action       InstitutionalAction
  prevShares   Decimal?            @db.Decimal(24, 2)
  filingDate   DateTime?           @db.Date
  acceptedDate DateTime?           @db.Date
  rawJson      Json? // put/call + share-class rows retained for reconciliation
  createdAt    DateTime            @default(now())

  fund InstitutionalFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, ticker, filingPeriod])
  @@index([filingPeriod])
  @@index([ticker, filingPeriod])
  @@index([cik, filingPeriod])
}

/// Per-fund per-quarter portfolio totals (FMP holder-performance-summary).
/// Supplies the book-value denominator for % of book + a cross-check on the
/// per-name add/remove counts. Append-only, one row per (fund, period).
model FundBookSnapshot {
  id                String   @id @default(cuid())
  fundId            String
  cik               String
  filingPeriod      DateTime @db.Date
  portfolioSize     Int? // # positions reported
  marketValue       Decimal? @db.Decimal(24, 2) // total 13F book $
  securitiesAdded   Int?
  securitiesRemoved Int?
  turnover          Float?
  rawJson           Json?
  createdAt         DateTime @default(now())

  fund InstitutionalFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, filingPeriod])
  @@index([filingPeriod])
}

/// Per-name × quarter aggregate over the tracked watchlist — powers the overview,
/// crowding-vs-conviction quadrant, and accumulation-trajectory views. Written by
/// the aggregation/diff service, not ingestion. Deciles are peer-relative ranks
/// (shared signal convention), NOT a blended score.
model InstitutionalNameAggregate {
  id                     String   @id @default(cuid())
  ticker                 String
  filingPeriod           DateTime @db.Date
  companyName            String?
  sector                 String?
  subsector              String?
  marketCapTier          String? // small | mid | large | mega
  fundsHolding           Int      @default(0)
  fundsNew               Int      @default(0)
  fundsAdded             Int      @default(0)
  fundsHeld              Int      @default(0)
  fundsTrimmed           Int      @default(0)
  fundsExited            Int      @default(0)
  fundsBought            Int      @default(0) // new + added
  fundsSold              Int      @default(0) // trimmed + exited
  deltaHolders           Int      @default(0) // vs prior quarter (bubble size)
  pctOfFunds             Float    @default(0) // breadth axis (% of tracked funds)
  medianPctOfBook        Float? // conviction axis
  totalValue             Decimal? @db.Decimal(24, 2)
  trajectoryLabel        String? // durable | accelerating | spike | choppy
  quadrant               String? // early | crowded | ignored | broad-low
  marketInvestorsHolding Int? // secondary market-wide crowding (context only)
  newArrival             Boolean  @default(false) // change detector
  breadthDecile          Int?
  convictionDecile       Int?
  createdAt              DateTime @default(now())

  @@unique([ticker, filingPeriod])
  @@index([filingPeriod])
  @@index([filingPeriod, fundsHolding])
}

/// Per-sector/subsector × quarter flow aggregate — powers sector rotation.
/// Mirrors RevisionSectorAggregate; keyed (groupType, groupKey, filingPeriod).
model InstitutionalSectorAggregate {
  id             String            @id @default(cuid())
  groupType      RevisionGroupType
  groupKey       String
  filingPeriod   DateTime          @db.Date
  netFundsAdding Int               @default(0) // (new+added) − (trimmed+exited)
  fundsAdding    Int               @default(0)
  fundsTrimming  Int               @default(0)
  nameCount      Int               @default(0)
  netValueFlow   Decimal?          @db.Decimal(24, 2)
  aggregatesJson Json?
  createdAt      DateTime          @default(now())

  @@unique([groupType, groupKey, filingPeriod])
  @@index([filingPeriod])
}

/// Cached landing-page payload per quarter (mirrors ResearchQueueSnapshot).
/// One row per filingPeriod, overwritten on recompute.
model InstitutionalQuarterSnapshot {
  id           String   @id @default(cuid())
  filingPeriod DateTime @unique @db.Date
  payloadJson  Json
  computedAt   DateTime @default(now())
}
